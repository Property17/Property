<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="myfatoorah_gateway.payment_method_form" inherit_id="payment.method_form">
    </template>

    <template id="inline_form">
        <div t-attf-id="myfatoorah-container-{{provider_id}}">
            <t t-call="myfatoorah_gateway.payment_details"/>
        </div>
    </template>

    <template id="myfatoorah_express_inline_form">
        <div t-attf-id="myfatoorah-container-{{provider_id}}">
            <t t-call="myfatoorah_gateway.payment_details"/>
        </div>
    </template>

    <template id="myfatoorah_express_checkout_form">
        <div name="o_myfatoorah_express_checkout_container"
             t-attf-id="o_myfatoorah_express_checkout_container_{{provider_sudo.id}}"
             t-att-data-provider-id="provider_sudo.id"
             t-att-data-provider-code="provider_sudo.code"
        >

            <button type="button"
                    class="btn btn-primary mt-2 w-100"
                    data-bs-toggle="modal"
                    t-attf-data-bs-target="#o_myfatoorah_payment_modal_{{provider_sudo.id}}"
            >
                Pay with MyFatoorah
                <span t-if="not provider_sudo.is_published"
                      class="badge rounded-pill text-bg-danger ms-1"
                >
                    Unpublished
                </span>
            </button>

            <div t-attf-id="o_myfatoorah_payment_modal_{{provider_sudo.id}}"
                 class="modal fade mt-5"
                 tabindex="-1"
                 aria-labelledby="o_myfatoorah_payment_modal_label"
                 aria-hidden="true"
            >

                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="o_myfatoorah_payment_modal_label">
                                MyFatoorah Express Checkout
                            </h5>
                            <span t-if="provider_sudo.state == 'test'"
                                  class="badge rounded-pill text-bg-warning ms-1"
                            >
                                Test Mode
                            </span>
                            <button type="button"
                                    class="btn-close"
                                    data-bs-dismiss="modal"
                                    aria-label="Close"
                            />
                        </div>
                        <div class="modal-body">
                            <t t-call="myfatoorah_gateway.myfatoorah_express_inline_form">
                                <t t-set="provider_id" t-value="provider_sudo.id"/>
                            </t>
                            <div class="float-end mt-2" t-att-data-provider-id="provider_sudo.id">
                                <t t-call="payment.submit_button">
                                    <t t-set="submit_button_label">Pay</t>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </template>

    <template id="payment_details">
        <div class="row">
            <div class="mb-3">
                <input name="provider_id" type="hidden" id="provider_id" t-att-value="id"/>
                <input name="partner_id" type="hidden" t-att-value="partner_id"/>
            </div>
            <div id="myfatoorah_container">
                <div class="mf-payment-methods-container" id="mf-noPaymentGateways">
                    <div class="mf-danger-text">
                        There are no payment methods available on your account, please contact your account manager.
                    </div>
                </div>
                <div class="mf-payment-methods-container" id="mf-paymentGateways">
                    <div class="mf-grey-text">
                        <t t-translation="on">How would you like to pay?</t>
                    </div>
                    <!-- Google Pay & Apple Pay -->
                    <div id="mf-sectionButtons">
                        <div id="mf-sectionAP">
                            <div id="mf-ap-element"></div>
                        </div>
                        <div id="mf-sectionGP">
                            <div id="mf-gp-element"></div>
                        </div>
                    </div>
                    <div id="mf-sectionCard">
                        <div class="mf-divider card-divider" id="mf-payWith-cardDivider">
                            <span class="mf-divider-span" id="mf-payWith-divider">
                                <span id="mf-or-cardsDivider">
                                    Or
                                </span>
                                Pay with
                            </span>
                        </div>
                        <div id="mf-cards"></div>
                    </div>
                    <div id="mf-form-element"></div>
                </div>
            </div>
        </div>
    </template>

</odoo>
