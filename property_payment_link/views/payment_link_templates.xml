<odoo>
    <data>
        <template id="property_payment_link.tenancy_payment_link_detail" name="Tenancy Payment Link Detail">
            <t t-call="website.layout">
                <style>
                    /* Tenant info: JS-injected on mobile, table on desktop */
                    @media (max-width: 991px) {
                        .payment-link-detail-container .payment-link-info-table { display: none !important; }
                        #payment-link-tenant-info { display: block !important; }
                    }
                    @media (min-width: 992px) {
                        #payment-link-tenant-info { display: none !important; }
                    }
                    #payment-link-tenant-info {
                        margin: 0.75rem 0; padding: 0.75rem; background: #f8f9fa; border-radius: 0.25rem;
                    }
                    #payment-link-tenant-info .pl-info-row {
                        display: flex; flex-wrap: wrap; padding: 0.5rem 0; border-bottom: 1px solid #dee2e6;
                    }
                    #payment-link-tenant-info .pl-info-row:last-child { border-bottom: none; }
                    #payment-link-tenant-info .pl-info-label { font-weight: 600; flex: 0 0 110px; font-size: 0.85rem; }
                    #payment-link-tenant-info .pl-info-value { flex: 1 1 calc(100% - 110px); word-break: break-word; font-size: 0.9rem; }
                    /* Hide only Odoo footer Pay; keep the node in DOM — MyFatoorah triggers it via .click() for some flows. */
                    #payment_method .o_payment_form button[name="o_payment_submit_button"] {
                        position: absolute !important;
                        width: 1px !important;
                        height: 1px !important;
                        padding: 0 !important;
                        margin: -1px !important;
                        overflow: hidden !important;
                        clip: rect(0, 0, 0, 0) !important;
                        white-space: nowrap !important;
                        border: 0 !important;
                    }
                </style>
                <div class="container payment-link-detail-container" data-pl-version="0.3">
                    <div class="row">
                
                        <h4 class="breadcrumb-item active col-12 payment-link-breadcrumb fw-bold"><strong>Payment
                                Link Details</strong></h4>
                        <div class="col-12 col-md-4 order-1 order-md-2 mb-3 mb-md-0">
                            <div class="payment-link-company-logo mx-auto mx-md-0 text-center text-md-end">
                                <img t-if="company_image_url" t-att-src="company_image_url" alt="Company Logo"
                                    class="img-fluid img-thumbnail payment-link-company-logo__img"/>
                            </div>
                        </div>
                        <div class="col-12 col-md-8 order-2 order-md-1">
                            <h4 class="payment-link-title text-center" t-esc="tenancy.company_id.name"/>
                            <!-- JS-injected on mobile (see payment_form_extend.js) -->
                            <div id="payment-link-tenant-info" t-att-data-tenant-info="tenancy_info_json"></div>
                            <!-- Desktop: table layout -->
                            <div class="table-responsive border-0 payment-link-info-table">
                                <table class="o_list_table position-relative table table-sm o_list_table_ungrouped table-striped o_portal_my_doc_table mb-0">
                                    <tbody>
                                        <tr>
                                            <td class="text-center"><span><strong>Property Manager</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.property_manager_id.name" /></td>
                                            <td></td>
                                            <td class="text-center"><span><strong>Tenant</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.tenant_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-center"><span><strong>Tenancy</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.name"/></td>
                                            <td></td>
                                            <td class="text-center"><span><strong>Phone</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.tenant_id.phone"/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-center"><span><strong>Property</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.property_id.name"/></td>
                                            <td></td>
                                            <td class="text-center"><span><strong>Email</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.tenant_id.email"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="o_portal_pager d-flex justify-content-center my-3"></div>
                    <div class="row">
                        <div class="col-12 col-lg-6 mb-4 mb-lg-0">
                            <div t-if="unpaid_rent_schedules and len(unpaid_rent_schedules) > 0">
                                <owl-component name="property_payment_link.tenancy_payment_invoice_line" t-att-props="json.dumps(tenancy_invoices_props)"/>
                            </div>
                            <div t-else="">
                                <h4 class="fw-bold"><strong>Invoices</strong></h4>
                                <div class="alert alert-info">
                                    <p>No unpaid invoices found.<t t-if="unpaid_rent_schedules"> (Count: <t t-esc="len(unpaid_rent_schedules)"/>)</t></p>
                                </div>
                            </div>
                            <!-- Total and Pay: always under Invoices (Total=0 when no unpaid) -->
                            <div class="table-responsive border-0 mt-2">
                                <table class="o_list_table position-relative table table-sm o_list_table_ungrouped table-striped o_portal_my_doc_table mb-0">
                                    <thead>
                                        <tr>
                                            <td class="text-center"><span><strong>Total</strong></span></td>
                                            <td id="InvoiceTotal"><t t-if="not (unpaid_rent_schedules and len(unpaid_rent_schedules) > 0)">0</t></td>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                            <t t-if="unpaid_rent_schedules and len(unpaid_rent_schedules) > 0">
                                <t t-if="tenancy.is_blocked or tenancy.state == 'blocked'">
                                    <button type="button" class="btn btn-secondary w-100 mt-2" disabled="disabled">
                                        <i class="fa fa-fw fa-ban"/> Pay
                                    </button>
                                    <div class="alert alert-warning mt-2 mb-0">
                                        <t>Payments are blocked for this tenancy. Please contact the property manager.</t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <a href="#" class="btn btn-primary w-100 mt-2" data-bs-toggle="modal" data-bs-target="#payment_method">
                                        <i class="fa fa-fw fa-arrow-circle-right"/> Pay
                                    </a>
                                </t>
                            </t>
                            <t t-else="">
                                <button type="button" class="btn btn-secondary w-100 mt-2" disabled="disabled">
                                    <i class="fa fa-fw fa-arrow-circle-right"/> Pay
                                </button>
                            </t>
                        </div>
                        <div class="col-12 col-lg-6" id="payment-receipt-section"
                             t-att-data-receipt-list="tenancy_payments_props.get('tenancy_payments_json', '[]')">
                            <h4><strong>Payment Receipt</strong></h4>
                            <t t-if="paid_rent_schedules and len(paid_rent_schedules) > 0">
                                <div class="table-responsive border-0 payment-link-receipt-table">
                                    <table class="o_list_table position-relative table table-sm o_list_table_ungrouped table-striped o_portal_my_doc_table mb-0">
                                        <thead>
                                            <tr>
                                                <td class="text-center"><span><strong>Date</strong></span></td>
                                                <td class="text-center"><span><strong>Invoice No</strong></span></td>
                                                <td class="text-center"><span><strong>Payment Date</strong></span></td>
                                                <td class="text-center"><span><strong>View</strong></span></td>
                                                <td class="text-center"><span><strong>Download</strong></span></td>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="tenancy_payments_props.get('tenancy_payments_list', [])" t-as="line">
                                                <tr>
                                                    <td class="text-center"><span t-esc="line.get('date', '')"/></td>
                                                    <td class="text-center"><span t-esc="line.get('invoice_name', '')"/></td>
                                                    <td class="text-center"><span t-esc="line.get('payment_date', '')"/></td>
                                                    <td class="text-center">
                                                        <a href="#" class="payment-receipt-view-btn" title="View"
                                                           t-att-data-schedule-id="line.get('rent_schedule_id')"
                                                           data-bs-toggle="modal"
                                                           data-bs-target="#view_payment"><i class="fa fa-filter"/></a>
                                                    </td>
                                                    <td class="text-center">
                                                        <a class="btn btn-sm btn-primary" role="button" target="_blank"
                                                           t-att-href="line.get('payment_link_report_url', '#')"
                                                           title="Download"><i class="fa fa-download"/></a>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="modal fade" id="view_payment" role="dialog" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-sm-down">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h3 class="modal-title">Payment Receipt</h3>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <div class="container">
                                                    <div class="row mb-2">
                                                        <div class="col-12 text-center">
                                                            <img class="d-inline-block" t-att-src="tenancy_payments_props.get('company_image_url', '')" alt="Company logo" style="max-width: 150px; height: auto;"/>
                                                        </div>
                                                    </div>
                                                    <div class="row mb-2" dir="rtl">
                                                        <div class="col-12 text-center">
                                                            <p class="mb-0 fw-bold" t-esc="tenancy_payments_props.get('company_name', '')"/>
                                                            <p class="mb-0 text-muted" t-esc="tenancy_payments_props.get('company_location', '')"/>
                                                        </div>
                                                    </div>
                                                    <h4 class="text-center">Payment Receipt: ايصال الدفع</h4>
                                                    <div class="table-table border-1 mt-3">
                                                        <table class="table table-sm" dir="rtl">
                                                            <tbody>
                                                                <tr><td class="text-end"><strong>رقم الايصال</strong></td><td class="text-center" id="modal_receipt_number"></td><td class="text-end"><strong>رقم العقد</strong></td><td class="text-center" id="modal_tenancy_name"></td><td class="text-end"><strong>تاريخ الاستحقاق</strong></td><td class="text-center" id="modal_invoice_due_date"></td></tr>
                                                                <tr><td class="text-end"><strong>رقم الوحدة</strong></td><td class="text-center" id="modal_unit" colspan="3"></td><td class="text-end"><strong>الرقم الالي</strong></td><td class="text-center" id="modal_unit_serial_number"></td></tr>
                                                                <tr><td class="text-end"><strong>وصلنا من السيد</strong></td><td class="text-center" id="modal_customer_name" colspan="5"></td></tr>
                                                                <tr><td class="text-end"><strong>عن الفترة</strong></td><td class="text-center" id="modal_period_formatted"></td><td class="text-end"><strong>ملاحظات</strong></td><td class="text-center" id="modal_paid_amount_words"></td><td class="text-end"><strong>القيمة الايجارية</strong></td><td class="text-center" id="modal_rental_value"></td></tr>
                                                                <tr><td class="text-end"><strong>المبلغ المدفوع</strong></td><td class="text-center" id="modal_paid_amount"></td><td colspan="2" class="text-center" id="modal_paid_amount_words_2"></td><td class="text-end"><strong>القيمة المتبقية</strong></td><td class="text-center" id="modal_residual_amount"></td></tr>
                                                                <tr><td class="text-end"><strong>تاريخ الدفع</strong></td><td class="text-center" id="modal_payment_date"></td><td class="text-end"><strong>طريقة الدفع</strong></td><td class="text-center" id="modal_payment_method"></td><td class="text-end"><strong>تفاصيل الدفع</strong></td><td class="text-center" id="modal_payment_details"></td></tr>
                                                                <tr><td class="text-end"><strong>اسم المحصل</strong></td><td class="text-center" id="modal_collector_name" colspan="5"></td></tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                    <div class="mt-4 pt-3 border-top" style="direction: rtl; text-align: center;">
                                                        <p class="mb-1 small text-muted">لا يعتبر الايصال صالحا مالم يكن مختوما وموقعا من قبل الشركة</p>
                                                        <p class="mb-0 small text-muted">هذا الايصال اثبات بالدفع فقط ولا يعتد به في تحديد القيمة الايجارية . يعتبر هذا الايصال لاغي في حالة عدم تحصيل الشيك</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="alert alert-info">
                                    <p>No payment receipts found.<t t-if="paid_rent_schedules"> (Count: <t t-esc="len(paid_rent_schedules)"/>)</t></p>
                                </div>
                            </t>
                        </div>
                    </div>

                    <div class="o_portal_pager d-flex justify-content-center my-3"></div>

                    <!-- Hidden input to store selected rent schedule IDs -->
                    <input type="hidden" id="selected_rent_schedule_ids" name="selected_rent_schedule_ids" value="[]"/>

                    <div class="modal fade" id="payment_method" role="dialog">
                        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h3 class="modal-title">Pay with</h3>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div t-if="company_mismatch">
                                        <t t-call="payment.company_mismatch_warning"/>
                                    </div>
                                    <div t-elif="not payment_methods_sudo and not tokens_sudo"
                                         class="alert alert-warning"
                                    >
                                        <strong>No suitable payment method could be found.</strong><br/>
                                        If you believe that it is an error, please contact the website
                                        administrator.
                                    </div>
                                    <t t-else="" t-call="payment.form"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
