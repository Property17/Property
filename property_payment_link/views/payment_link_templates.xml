<odoo>
    <data>
        <template id="property_payment_link.tenancy_payment_link_detail" name="Tenancy Payment Link Detail">
            <t t-call="website.layout">
                <div class="container">
                    <div class="row">
                        <p class="breadcrumb-item active" >Payment Link Details
                        </p>
                        <div class="col-8">
                            <h4 t-esc="tenancy.company_id.name"/>
                            <div class="table-responsive border-0 ">
                                <table class="o_list_table position-relative table table-sm o_list_table_ungrouped table-striped o_portal_my_doc_table mb-0">
                                    <tbody>
                                        <tr>
                                            <td class="text-center"><span><strong>Property Manager</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.manager_id.name"/></td>
                                            <td></td>
                                            <td class="text-center"><span><strong>Tenant</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.tenant_id.name"/></td>
                                        </tr>                                            <tr>
                                        <td class="text-center"><span><strong>Tenancy</strong></span></td>
                                        <td class="text-center"><span t-esc="tenancy.name"/></td>
                                        <td></td>
                                        <td class="text-center"><span><strong>Phone</strong></span></td>
                                        <td class="text-center"><span t-esc="tenancy.tenant_id.phone"/></td>
                                    </tr>
                                        <tr>
                                            <td class="text-center"><span><strong>Property</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.property_id.name"/></td>
                                            <td></td>
                                            <td class="text-center"><span><strong>Email</strong></span></td>
                                            <td class="text-center"><span t-esc="tenancy.tenant_id.email"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="col-4">
                            <span t-esc="tenancy.company_id.logo" t-options="{'widget': 'image','class': 'mx-auto d-block img-thumbnail'}"/>
                        </div>
                    </div>
                    <div class="o_portal_pager d-flex justify-content-center my-3">
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <t t-set="unpaid_rent_schedules" t-value="tenancy.rent_schedule_ids.filtered(lambda rs: rs.move_check and not rs.paid)"/>
                            <t t-set="tenancy_lines_dict" t-value="{
                                        rs.id: [{
                                                    'rent_schedule_id': rs.id,
                                                    'date': str(rs.start_date),
                                                    'invoice_name': rs.invoice_id.name if rs.invoice_id else '',
                                                    'invoice_date_due': str(rs.invoice_id.invoice_date_due) if rs.invoice_id and rs.invoice_id.invoice_date_due else '',
                                                    'invoice_amount_residual': rs.amount,
                                                    }] for rs in unpaid_rent_schedules
                                    }"/>
                            <t t-set="flexible_payment_value" t-value="tenancy.flexible_payment if tenancy.flexible_payment is not None else False"/>
                            <t t-set="tenancy_invoices_props" t-value="{
                                        'tenancy_lines': tenancy_lines_dict,
                                        'flexible_payment': flexible_payment_value,
                                    }"/>

                            <div t-if="unpaid_rent_schedules and len(unpaid_rent_schedules) > 0">
                                <owl-component name="property_payment_link.tenancy_payment_invoice_line" t-att-props="json.dumps(tenancy_invoices_props)"/>
                            </div>
                            <div t-else="" class="alert alert-info">
                                <p>No unpaid invoices found.<t t-if="unpaid_rent_schedules"> (Count: <t t-esc="len(unpaid_rent_schedules)"/>)</t></p>
                            </div>
                        </div>
                        <div class="col-1"></div>
                        <div class="col-5">
                            <t t-set="paid_rent_schedules" t-value="tenancy.rent_schedule_ids.filtered(lambda rs: rs.move_check and rs.paid and rs.invoice_id and rs.invoice_id.invoice_payments_widget and rs.invoice_id.invoice_payments_widget.get('content') and len(rs.invoice_id.invoice_payments_widget['content']) > 0)"/>
                            <t t-set="tenancy_payments_props" t-value="{
                                        'tenancy_lines': {
                                            rs.id: [{
                                                    'payment_id': str(rs.invoice_id.invoice_payments_widget['content']),
                                                    'date': str(rs.start_date),
                                                    'invoice_id': rs.invoice_id.id,
                                                    'invoice_token': rs.invoice_id.access_token,
                                                    'invoice_name': rs.invoice_id.name,
                                                    'payment_link_report_url': '/tenancy_payment_link/tenant_partner/payment_report/%s?access_token=%s' % (rs.invoice_id.id, rs.invoice_id.access_token),
                                                    'payment_date': str(rs.invoice_id.invoice_payments_widget['content'][0]['date']),
                                                    'tenancy_id': tenancy.id,
                                                    'tenancy_name': tenancy.name,
                                                    'invoice_due_date': str(rs.invoice_id.invoice_date_due),
                                                    'invoice_amount': rs.amount,
                                                    'customer_name': tenancy.tenant_id.name,
                                                    'unit': tenancy.property_id.name,
                                                    'unit_serial_number': tenancy.property_id.auto_add_no or '',
                                                    'paid_amount': str(rs.invoice_id.invoice_payments_widget['content'][0]['amount']),
                                                    'paid_amount_words': tenancy.change_amount_to_word(rs.invoice_id.invoice_payments_widget['content'][0]['amount'], 'ar_001'),
                                                    'residual_amount': rs.invoice_id.amount_residual,
                                                    'payment_transaction_id': str(rs.invoice_id.invoice_payments_widget['content'][0]['date']),
                                                    'payment_method': str(rs.invoice_id.invoice_payments_widget['content'][0]['payment_method_name']),
                                                    'reference_number': str(rs.invoice_id.invoice_payments_widget['content'][0]['ref']),

                                                    }] for rs in paid_rent_schedules
                                            },
                                        'company_image_url': company_image_url
                                    }"/>
                            <div t-if="paid_rent_schedules and len(paid_rent_schedules) > 0">
                                <owl-component name="property_payment_link.tenancy_payment_invoice_receipt" t-att-props="json.dumps(tenancy_payments_props)"/>
                            </div>
                            <div t-else="" class="alert alert-info">
                                <p>No paid invoices found.<t t-if="paid_rent_schedules"> (Count: <t t-esc="len(paid_rent_schedules)"/>)</t></p>
                            </div>
                        </div>
                    </div>

                    <div class="o_portal_pager d-flex justify-content-center my-3">
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="row">
                                <div class="col-6">
                                    <a  href="#"
                                        class="btn btn-primary d-block mb-2"
                                        data-bs-toggle="modal"
                                        data-bs-target="#payment_method">
                                        <i class="fa fa-fw fa-arrow-circle-right"/> Pay
                                    </a>
                                </div>
                                <div class="col-6">
                                    <div class="table-responsive border-0 ">
                                        <table class="o_list_table position-relative table table-sm o_list_table_ungrouped table-striped o_portal_my_doc_table mb-0">
                                            <thead>
                                                <tr>
                                                    <td class="text-center">
                                                        <span><strong>Total</strong></span>
                                                    </td>
                                                    <td id="InvoiceTotal"></td>
                                                </tr>
                                            </thead>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">

                        </div>
                    </div>
                    <div class="o_portal_pager d-flex justify-content-center my-3">

                    </div>

                    <!-- Hidden input to store selected rent schedule IDs -->
                    <input type="hidden" id="selected_rent_schedule_ids" name="selected_rent_schedule_ids" value="[]"/>

                    <div class="modal fade" id="payment_method" role="dialog">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h3 class="modal-title">Pay with</h3>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div t-if="company_mismatch">
                                        <t t-call="payment.company_mismatch_warning"/>
                                    </div>
                                    <div t-elif="not payment_methods_sudo and not tokens_sudo"
                                         class="alert alert-warning"
                                    >
                                        <strong>No suitable payment method could be found.</strong><br/>
                                        If you believe that it is an error, please contact the website
                                        administrator.
                                    </div>
                                    <t t-else="" t-call="payment.form"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
