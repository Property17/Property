<odoo>

    <!-- Inherited form view of crm lead -->
    <record id="property_analytic_view_form_inherit" model="ir.ui.view">
        <field name="name">property.analytic.view.form.inherit</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="property_management.property_analytic_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_view_payment_links" string="Tenant Payment Link" type="object"
                    icon="fa-link" class="btn-secondary"
                    invisible="state != 'open'"
                    help="Create or open the portal payment link for this tenancy (calls create_payment_link if none exists)."/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_payment_links" type="object"
                    class="oe_stat_button" icon="fa-link"
                    invisible="payment_link_count == 0">
                    <field name="payment_link_count" widget="statinfo" string="Payment Links"/>
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="after">
                <div class="oe_avatar" style="padding: 8px;">
                    <div style="display: flex; flex-direction: column; gap: 8px; align-items: flex-end;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <label for="is_blocked" string="Block Payments" style="margin: 0;"/>
                            <field name="is_blocked" widget="boolean_toggle"/>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <label for="flexible_payment" string="Flexible Payments" style="margin: 0;"/>
                            <field name="flexible_payment" widget="boolean_toggle"/>
                        </div>
                    </div>
                </div>
            </xpath>


            <!-- <group>
                <div class="oe_right">
                    <div style="display: flex; align-items: center; margin-bottom: 8px; gap: 8px;">
                        <label for="is_blocked" string="Block Payments" style="margin: 0;" />
                        <field name="is_blocked" widget="boolean_toggle" />
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <label for="flexible_payment" string="Flexible Payments" style="margin: 0;" />
                        <field name="flexible_payment" widget="boolean_toggle" />
                    </div>
                </div>
            </group> -->
           
        </field>
    </record>
</odoo>
