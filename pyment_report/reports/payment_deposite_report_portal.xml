<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal payment-link download: single deposit receipt (backend report unchanged) -->
    <record id="action_report_payment_deposite_receipt_portal" model="ir.actions.report">
        <field name="name">Deposite Report (Portal)</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pyment_report.report_payment_deposite_document_portal</field>
        <field name="report_file">pyment_report.report_payment_deposite_document_portal</field>
        <field name="paperformat_id" ref="pyment_report.paperformat_payment_report"/>
    </record>

    <template id="report_payment_deposite_document_portal">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .gs_table {
                            border-collapse: collapse;
                            border: 1px solid #000000;
                            float:right !important;
                            width:100%;
                            margin:auto;
                            }
                            .gs_table td {
                            height: 35px;
                            border-bottom: 1px solid #000000;
                            vertical-align: middle;
                            font-size:18px;
                            padding:5;
                            }
                            .gs_table th {
                            height: 35px;
                            border-bottom: 1px solid #000000;
                            vertical-align: middle;
                            font-size:18px;
                            padding:5;
                            }
                        </style>
                        <br/>
                        <br/>
                        <table style="text-align: center;width:100%;border:1px solid #ffffff;">
                            <tr>
                                <th style="text-align: center;">ايصال  تأمين</th>
                            </tr>
                        </table>
                        <table class="mt-2 gs_table" style="border:1;direction:rtl;width:100%;">
                            <tr>
                                <th style="background-color:#D8D8D8;text-align: right;width:15%;">رقم الايصال</th>
                                <td style="text-align: right;width:17%;"><span t-field="o.name"/></td>
                                <th style="background-color:#D8D8D8;text-align: right;width:12%;">رقم العقد</th>
                                <td style="text-align: right;width:22%;"><span t-field="o.tenancy_id.code"/></td>
                                <th style="background-color:#D8D8D8;text-align: right;width:16%;">تاريخ الاستحقاق</th>
                                <td style="text-align: right;width:18%;"><span t-field="o.date"/></td>
                            </tr>
                            <tr>
                                <th style="background-color:#D8D8D8;text-align: right;">رقم الوحدة</th>
                                <td t-if="o.mm_move_id.properitis" colspan="3" style="text-align: right;">
                                    <span t-field="o.mm_move_id.properitis"/>
                                </td>
                                <td t-else="o.properitis" colspan="3" style="text-align: right;">
                                    <span t-field="o.properitis"/>
                                </td>
                                <th style="background-color:#D8D8D8;text-align: right;">الرقم الالي</th>
                                <td style="text-align: right;"><span t-field="o.property_id.auto_add_no"/></td>
                            </tr>
                            <tr>
                                <th style="background-color:#D8D8D8;text-align: right;">وصلنا من السيد</th>
                                <td colspan="5" style="text-align: right;"><span t-field="o.partner_id.name"/></td>
                            </tr>
                            <tr>
                                <th style="background-color:#D8D8D8;text-align: right;">وذلك عن</th>
                                <td colspan="5" style="text-align: right;font-size: 14px;">
                                    <span>تأمين يسترد عند الاخلاء بشرط التنبية بقبل شهرين بكتاب رسمي والاخلاء قبل بأسبوع من الشهر الاخير</span>
                                </td>
                            </tr>
                            <tr>
                                <th style="background-color:#D8D8D8;text-align: right;">المبلغ المدفوع</th>
                                <td style="text-align: right;"><span t-field="o.amount"/></td>
                                <td colspan="2" style="text-align: right;"><span t-field="o.amount_char"/></td>
                                <th style="background-color:#D8D8D8;text-align: right;">قيمة التأمين</th>
                                <td style="text-align: right;"><span t-field="o.amount"/></td>
                            </tr>
                            <tr>
                                <th style="background-color:#D8D8D8;text-align: right;">تاريخ الدفع</th>
                                <td style="text-align: right;"><span t-field="o.date"/></td>
                                <th style="background-color:#D8D8D8;text-align: right;">طريقة الدفع</th>
                                <td style="text-align: right;"><span t-field="o.payment_method_line_id.name"/></td>
                                <th style="background-color:#D8D8D8;text-align: right;">تفاصيل الدفع</th>
                                <td style="text-align: right;"><span t-field="o.ref"/></td>
                            </tr>
                            <tr>
                                <th style="background-color:#D8D8D8;text-align: right;">اسم المحصل</th>
                                <td colspan="3" style="text-align: right;"><span t-field="o.user_id.name"/></td>
                                <th style="background-color:#D8D8D8;text-align: right;">التوقيع / الختم</th>
                                <td style="text-align: right;"><span>.</span></td>
                            </tr>
                        </table>
                        <div style="text-align: center;direction: ltr;">
                            <span style="text-align: right;direction: ltr;">لا يعتبر الايصال صالحا مالم يكن مختوما وموقعا من قبل الشركة .</span>
                            <br/>
                            <span style="text-align: right;direction: ltr;">هذا الايصال اثبات بالدفع فقط ولا يعتد به في تحديد القيمة الايجارية .</span>
                            <br/>
                            <span style="text-align: right;direction: ltr;">يعتبر هذا الايصال لاغي في حالة عدم تحصيل الشيك .</span>
                        </div>
                        <div style="text-align: right;direction: ltr; margin-top: 12px;">
                            <span t-field="o.property_id.property_manager.name"/>
                            <br/>
                            <span t-field="o.mm_move_id.property_manager_id.street"/>-<span t-field="o.mm_move_id.property_manager_id.street2"/>-<span t-field="o.mm_move_id.property_manager_id.city"/>-
                            <span t-field="o.mm_move_id.property_manager_id.country_id.name"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
